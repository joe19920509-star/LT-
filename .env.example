# PostgreSQL（本地 Docker 见项目根目录 docker-compose.yml）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ltmagazine"

# Neon / Supabase 等托管商会提供完整 URL，通常含 ?sslmode=require

# Session secret — 至少 32 位随机串（生产务必更换）
SESSION_SECRET="replace-with-at-least-32-characters-secret-key!!"

# 后台 /admin 发稿密码（仅用于数据库文章；勿泄露）
ARTICLE_ADMIN_PASSWORD="change-this-strong-password"

# 公网站点地址（生产设为 https://ltmagazine.cn）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
